# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reserve

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# JWT (admin auth). Leave JWT_SECRET_KEY empty to use SECRET_KEY.
# JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
WORKERS=4

# Connection pools
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
REDIS_POOL_SIZE=10

# Cache TTL (seconds)
CACHE_SLOTS_TTL=90
CACHE_TABLES_TTL=120

# Lock TTL (seconds)
LOCK_TTL_SECONDS=10
