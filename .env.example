# Application Environment
# Options: development, staging, production
APP_ENV=development

# Secret Key (required in production, must be at least 32 characters)
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-please-no-error

# JWT Configuration
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Server Configuration
WORKERS=4

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reserve
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Cache TTL (seconds)
CACHE_SLOTS_TTL=90
CACHE_TABLES_TTL=120

# Lock TTL (seconds)
LOCK_TTL_SECONDS=10

# Logging
LOG_LEVEL=INFO
