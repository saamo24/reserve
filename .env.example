# Application Environment
# Options: development, staging, production
APP_ENV=development

# Secret Key (required in production, must be at least 32 characters)
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-please-no-error

# JWT Configuration
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Server Configuration
WORKERS=4

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reserve
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Cache TTL (seconds)
CACHE_SLOTS_TTL=90
CACHE_TABLES_TTL=120

# Lock TTL (seconds)
LOCK_TTL_SECONDS=10

# Logging
LOG_LEVEL=INFO

# Email/SMTP (optional; leave SMTP_HOST empty to skip sending email)
# If Gmail times out (e.g. in Docker/cloud), try SMTP_PORT=465 or use an HTTP API (SendGrid, Mailgun, Resend).
SMTP_HOST=
SMTP_PORT=587
SMTP_TIMEOUT=30
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true
ADMIN_EMAIL=
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
